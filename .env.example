# Copy to .env.local and fill in. Never commit real secrets.

# --- Map (public) ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Database (Postgres / Neon) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Auth (Auth.js) ---
AUTH_SECRET=            # generate with: openssl rand -base64 32
AUTH_TRUST_HOST=true

# --- Seed admin (optional; defaults used for local dev) ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Email (Resend) ---
RESEND_API_KEY=         # from resend.com/api-keys
CONTACT_TO_EMAIL=info@truelightbaptist.org      # where website emails are delivered
CONTACT_FROM_EMAIL=noreply@updates.truelightbaptist.org # must be on a Resend-verified (sub)domain

# --- Media uploads (Vercel Blob) ---
# Required in production so /admin/media can upload files on Vercel's read-only filesystem.
BLOB_READ_WRITE_TOKEN=
